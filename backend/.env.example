# Copy to .env and fill in.
DATABASE_URL=sqlite:///./hospital_prep.db
REDIS_URL=redis://localhost:6379/0

# Cursor API keys — used for briefing LLM + document OCR (vision)
CURSOR_API_KEY=
CURSOR_API_KEY_2=
CURSOR_MODEL=composer-2.5

# Optional meal video recommendations
YOUTUBE_API_KEY=
USDA_API_KEY=

CELERY_BEAT_INTERVAL_SECONDS=45
QUEUE_AGING_RATE=1.0
QUEUE_AUTO_ESCALATE_MINUTES=45
SELF_CARE_APPROVAL_WINDOW_HOURS=24
ICD10_SIMILARITY_THRESHOLD=0.75
